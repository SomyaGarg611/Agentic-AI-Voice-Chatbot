ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=your_deepgram_key
ELEVENLABS_API_KEY=your_elevenlabs_key
TAVILY_API_KEY=your_tavily_key          # optional — enables web search tool
LANGFUSE_PUBLIC_KEY=                    # optional — enables tracing dashboard
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Auth (multi-user) ──────────────────────────────────────────────────────
# Google Sign-In: create an OAuth 2.0 "Web application" Client ID in Google
# Cloud Console, add your origin (e.g. http://localhost:8000) to Authorized
# JavaScript origins, and paste the Client ID here. Leave empty to use the
# built-in dev email login instead (fine for local development).
GOOGLE_CLIENT_ID=
# Secret used to sign session tokens — set a long random string in production.
JWT_SECRET=dev-insecure-change-me
